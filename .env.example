# TxLINE feed — SERVER-SIDE ONLY. Copy to .env.local and fill in.
# Never expose these to the browser; the SSE relay (app/api/stream) holds them
# and only proxies the feed out.
#
# Confirm exact host + endpoint paths against the TxLINE docs before relying on
# the guest/subscribe/activate flow.

# Base URL for TxLINE REST (auth, snapshots, merkle proofs).
# Published base is https://txline.txodds.com (see docs/ONCHAIN_SETUP.md).
TXLINE_API_BASE=
# Base URL for the SSE streams (often the same host). Falls back to TXLINE_API_BASE.
TXLINE_SSE_BASE=

# Optional app/client id some guest-auth deployments require.
TXLINE_CLIENT_ID=

# Service Level that unlocks the sub-second SL12 feed.
TXLINE_SERVICE_LEVEL_ID=12

# Tx signature of the on-chain subscribe transaction (devnet), produced
# out-of-band with a funded keypair + the TxLINE Anchor program. Consumed by the
# token/activate exchange. Leave blank until the subscribe step is done.
TXLINE_SUBSCRIBE_TXSIG=

# Shortcut for local dev: a pre-issued API token. When set, the relay uses it
# directly and skips the guest+subscribe+activate exchange.
TXLINE_API_TOKEN=

# ── On-chain layer (Plan B — Solana / devnet) ───────────────────────────────
# BROWSER-SAFE (NEXT_PUBLIC_*). Addresses are baked into lib/chain/config.ts from
# the published TxLINE docs; only override here if you redeploy. World Cup access
# is free (SL 1 = 60s delay, SL 12 = real-time): no TxL payment, but a one-time
# on-chain register tx is still required. Full guide: docs/ONCHAIN_SETUP.md.

NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# Optional RPC override (defaults to the public devnet/mainnet endpoint).
NEXT_PUBLIC_SOLANA_RPC=
# Sway's own Metaplex Core collection / mint authority. When unset, the mint
# button stays disabled; capture + Merkle verify still work (judge mode).
NEXT_PUBLIC_SWAY_COLLECTION=

# Path to a funded devnet keypair JSON (SERVER-SIDE ONLY) — gas for the subscribe
# register tx and the judge-mode mint fee-payer. Never expose to the browser.
TXLINE_SUBSCRIBE_KEYPAIR=
